# コピーして .env を作成する: cp .env.example .env

# LLMプロバイダ切り替え(docs/DESIGN.md §4): "anthropic" | "gemini"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8

# 各プロバイダのAPIキー(使用するものだけ設定)
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# DB(省略時: sqlite:///./data/app.db。AWS移行時にPostgreSQLのURLへ差し替え)
# DATABASE_URL=sqlite:///./data/app.db
